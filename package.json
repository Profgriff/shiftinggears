{
  "name": "shiftinggears",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create roc-scheduler-db",
    "db:migrate:local": "wrangler d1 execute roc-scheduler-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute roc-scheduler-db --remote --file=./migrations/0001_init.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
